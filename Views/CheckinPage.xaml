<Page x:Class="AccommodationSystem.Views.CheckinPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:svc="clr-namespace:AccommodationSystem.Services"
      Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 検索エリア -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="40,30,40,16">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=SearchTitle}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=SearchLabel}"
                           Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Margin="0,0,12,0"
                             FontSize="16" Padding="12,10"
                             KeyDown="SearchBox_KeyDown"
                             Style="{StaticResource PlaceholderTextBox}"
                             Tag="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=SearchPlaceholder}"/>
                    <Button Grid.Column="1"
                            Content="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=SearchBtn}"
                            Style="{StaticResource PrimaryButton}"
                            Click="SearchButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 検索結果 -->
        <Border Grid.Row="1" Margin="40,0,40,30">
            <Grid>
                <!-- 初期メッセージ -->
                <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🏨" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=WelcomeTitle}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"
                               Margin="0,16,0,8"/>
                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=WelcomeDesc1}"
                               HorizontalAlignment="Center"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=WelcomeDesc2}"
                               HorizontalAlignment="Center"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- 検索結果リスト -->
                <ListView x:Name="ResultList" Visibility="Collapsed"
                          SelectionChanged="ResultList_SelectionChanged"
                          Background="Transparent" BorderThickness="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                                Padding="20,14" Margin="0,4">
                                            <Border.Effect>
                                                <DropShadowEffect Opacity="0.07" BlurRadius="8" ShadowDepth="1"/>
                                            </Border.Effect>
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EBF4FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 宿泊者名 + 予約詳細 -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run Text="{Binding GuestName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0">
                                        <Run Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=ItemResNum, Mode=OneWay}"/>
                                        <Run Text="{Binding ReservationNumber}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=ItemCheckin, Mode=OneWay}"/>
                                        <Run Text="{Binding CheckinDate, StringFormat=\{0:yyyy/MM/dd\}}"/>
                                        <Run Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=ItemDash, Mode=OneWay}"/>
                                        <Run Text="{Binding CheckoutDate, StringFormat=\{0:yyyy/MM/dd\}}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding NumPersons}"/>
                                        <Run Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=SuffixPersons, Mode=OneWay}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding NumNights}"/>
                                        <Run Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=SuffixNights, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 宿泊税金額 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                    <TextBlock Text="{Binding AccommodationTax, StringFormat=\{0:¥#\,##0\}}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=ItemTaxLbl}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>

                                <!-- 支払状況バッジ -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <!-- Text driven by LocalizationProxy so it updates on language toggle -->
                                    <TextBlock FontSize="12" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!-- default = unpaid -->
                                                <Setter Property="Text"
                                                        Value="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=StatusUnpaid}"/>
                                                <Setter Property="Foreground" Value="#92400E"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                        <Setter Property="Text"
                                                                Value="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=StatusPaid}"/>
                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 検索結果なし -->
                <StackPanel x:Name="NoResultPanel" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static svc:LocalizationProxy.Instance}, Path=NoResult}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
